# OpenAI 호환 API 설정
# 아래 값을 채운 뒤 파일 이름을 .env 로 바꾸세요.

# 필수: API 시크릿 키
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# 필수: API base URL (끝에 /v1 까지 포함)
# 예) OpenAI          : https://api.openai.com/v1
#     Together AI     : https://api.together.xyz/v1
#     Groq            : https://api.groq.com/openai/v1
#     OpenRouter      : https://openrouter.ai/api/v1
#     로컬 vLLM/Ollama : http://localhost:8000/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 임베딩 모델 (문서를 벡터로 변환)
EMBEDDING_MODEL=text-embedding-3-small

# 채팅 모델 (답변 생성)
CHAT_MODEL=gpt-4o-mini

# --- 아래는 선택 사항 (기본값 사용 가능) ---

# 문서 조각 하나의 최대 글자 수
CHUNK_SIZE=800

# 인접한 조각끼리 겹치는 글자 수 (문맥 유실 방지)
CHUNK_OVERLAP=120

# 질문 1건당 검색해서 LLM에 넘길 조각 개수
TOP_K=5

# 인덱스(벡터 DB) 저장 경로
INDEX_DIR=storage

# 원본 문서를 넣어둘 폴더
DOCS_DIR=docs
